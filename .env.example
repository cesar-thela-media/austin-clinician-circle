# ── Clerk Auth ──────────────────────────────────────────────────────────────
# https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# Redirect URLs registered in Clerk dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard/billing

# Comma-separated emails that get admin access
CLERK_ADMIN_EMAILS=sarah@restoredfc.com

# ── Resend Email ─────────────────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_...

# Verified sending domain in Resend
RESEND_FROM_EMAIL=Austin Clinician Circle <hello@austincliniciancircle.com>

# Sarah's notification inbox
SARAH_EMAIL=sarah@restoredfc.com

# ── Stripe Billing ───────────────────────────────────────────────────────────
# Use test keys for staging, live keys for production
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe portal redirect URLs
STRIPE_SANDBOX_SUCCESS_URL=https://austincliniciancircle.com/dashboard/billing?checkout=success
STRIPE_SANDBOX_CANCEL_URL=https://austincliniciancircle.com/join?checkout=cancelled

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://austincliniciancircle.com
